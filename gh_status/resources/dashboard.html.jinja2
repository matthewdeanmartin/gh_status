<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ username }} GitHub Status</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    :root {
      --bg: #f3ecdf;
      --bg-deep: #e6dcc8;
      --panel: rgba(255, 251, 245, 0.78);
      --panel-strong: rgba(255, 252, 248, 0.92);
      --ink: #17211d;
      --muted: #59655d;
      --line: rgba(23, 33, 29, 0.12);
      --accent: #1d6b57;
      --accent-2: #ca6930;
      --accent-3: #27495c;
      --shadow: 0 28px 80px rgba(19, 27, 25, 0.14);
    }

    * { box-sizing: border-box; }

    html, body {
      margin: 0;
      min-height: 100%;
      color: var(--ink);
      background:
        radial-gradient(circle at top left, rgba(29, 107, 87, 0.18), transparent 30%),
        radial-gradient(circle at top right, rgba(202, 105, 48, 0.18), transparent 26%),
        linear-gradient(180deg, #faf6ef 0%, var(--bg) 52%, var(--bg-deep) 100%);
      font-family: Georgia, "Times New Roman", serif;
    }

    body {
      min-height: 100vh;
    }

    a { color: var(--accent); }

    .app-shell {
      min-height: 100vh;
      display: grid;
      grid-template-rows: auto 1fr;
      position: relative;
      overflow: hidden;
    }

    .ambient {
      position: fixed;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 20% 18%, rgba(29, 107, 87, 0.12), transparent 0 24%),
        radial-gradient(circle at 82% 14%, rgba(39, 73, 92, 0.12), transparent 0 20%),
        radial-gradient(circle at 72% 78%, rgba(202, 105, 48, 0.16), transparent 0 24%);
      filter: blur(8px);
    }

    .topbar {
      position: relative;
      z-index: 1;
      display: flex;
      justify-content: space-between;
      gap: 16px;
      align-items: center;
      padding: 18px 22px 0;
      flex-wrap: wrap;
    }

    .brand,
    .top-actions,
    .app-card {
      border: 1px solid var(--line);
      background: var(--panel);
      box-shadow: var(--shadow);
      backdrop-filter: blur(14px);
    }

    .brand {
      border-radius: 999px;
      padding: 10px 14px;
      display: inline-flex;
      align-items: center;
      gap: 12px;
    }

    .brand-mark {
      width: 11px;
      height: 11px;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      box-shadow: 0 0 0 6px rgba(29, 107, 87, 0.08);
    }

    .brand-copy {
      display: grid;
      gap: 2px;
    }

    .eyebrow {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: var(--muted);
    }

    .brand strong {
      font-size: 0.95rem;
    }

    .top-actions {
      border-radius: 999px;
      padding: 6px;
      display: flex;
      gap: 6px;
      align-items: center;
      flex-wrap: wrap;
    }

    button,
    .link-button {
      appearance: none;
      border: 0;
      border-radius: 999px;
      padding: 11px 15px;
      font: inherit;
      cursor: pointer;
      color: var(--ink);
      background: rgba(255, 255, 255, 0.72);
      transition: transform 140ms ease, background 140ms ease, color 140ms ease;
      text-decoration: none;
    }

    button:hover,
    .link-button:hover {
      transform: translateY(-1px);
      background: rgba(255, 255, 255, 0.96);
    }

    button.is-active {
      background: linear-gradient(135deg, var(--accent), var(--accent-3));
      color: #fff;
    }

    .app-card {
      position: relative;
      z-index: 1;
      margin: 16px 22px 22px;
      border-radius: 28px;
      min-height: calc(100vh - 110px);
      display: grid;
      grid-template-columns: minmax(0, 1fr) 280px;
      overflow: hidden;
    }

    .stage {
      position: relative;
      min-height: 70vh;
      padding: 24px;
      display: grid;
      grid-template-rows: auto 1fr auto;
      gap: 18px;
    }

    .stage-header {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      align-items: center;
      flex-wrap: wrap;
    }

    .stage-meta {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      color: var(--muted);
      font-size: 0.95rem;
    }

    .meta-chip {
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 8px 12px;
      background: rgba(255, 255, 255, 0.58);
    }

    .slide-frame {
      position: relative;
      min-height: 58vh;
      border-radius: 24px;
      border: 1px solid var(--line);
      background:
        linear-gradient(160deg, rgba(255, 255, 255, 0.92), rgba(248, 242, 233, 0.78)),
        linear-gradient(135deg, rgba(29, 107, 87, 0.06), rgba(202, 105, 48, 0.06));
      overflow: hidden;
    }

    .slide-frame::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(90deg, rgba(29, 107, 87, 0.04), transparent 16%),
        linear-gradient(0deg, rgba(255, 255, 255, 0.3), transparent 24%);
      pointer-events: none;
    }

    .slide {
      position: absolute;
      inset: 0;
      padding: clamp(22px, 4vw, 42px);
      display: grid;
      gap: 18px;
      align-content: start;
      opacity: 0;
      transform: translateX(48px) scale(0.985);
      transition: opacity 260ms ease, transform 260ms ease;
      pointer-events: none;
      overflow-y: auto;
    }

    .slide.is-active {
      opacity: 1;
      transform: translateX(0) scale(1);
      pointer-events: auto;
    }

    .slide-kicker {
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--muted);
    }

    .slide h1,
    .slide h2 {
      margin: 0;
      font-size: clamp(2.2rem, 5vw, 4.8rem);
      line-height: 0.95;
      letter-spacing: -0.05em;
      max-width: 12ch;
    }

    .slide h2 {
      font-size: clamp(1.8rem, 4vw, 3.4rem);
      max-width: 14ch;
    }

    .lede {
      max-width: 72ch;
      color: var(--muted);
      line-height: 1.65;
      font-size: 1.08rem;
    }

    .hero-stats,
    .fact-grid,
    .repo-grid,
    .todo-grid,
    .feed-grid {
      display: grid;
      gap: 14px;
    }

    .hero-stats,
    .fact-grid {
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    }

    .repo-grid,
    .todo-grid {
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }

    .feed-grid {
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    }

    .stat-card,
    .fact-card,
    .repo-card,
    .todo-card,
    .feed-card,
    .event-card,
    .quote-card {
      border: 1px solid var(--line);
      border-radius: 22px;
      background: var(--panel-strong);
      padding: 18px;
      box-shadow: 0 18px 48px rgba(18, 24, 22, 0.08);
    }

    .stat-value,
    .fact-value {
      display: block;
      margin-top: 10px;
      font-size: clamp(1.8rem, 3vw, 3rem);
      line-height: 1;
    }

    .card-label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--muted);
    }

    .detail {
      margin-top: 10px;
      color: var(--muted);
      line-height: 1.55;
    }

    .event-card {
      display: grid;
      gap: 14px;
      max-width: 860px;
    }

    .event-top {
      display: flex;
      gap: 12px;
      align-items: center;
      flex-wrap: wrap;
    }

    .event-pill,
    .repo-chip,
    .topic-chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border-radius: 999px;
      padding: 7px 11px;
      background: rgba(29, 107, 87, 0.08);
      color: var(--accent);
      font-size: 0.88rem;
    }

    .quote-card {
      border-left: 6px solid var(--accent-2);
      max-width: 760px;
      font-size: 1.08rem;
      line-height: 1.65;
    }

    .list {
      display: grid;
      gap: 10px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .list li {
      padding: 12px 14px;
      border-radius: 16px;
      background: rgba(29, 107, 87, 0.06);
      border: 1px solid rgba(29, 107, 87, 0.08);
    }

    .deck-controls {
      display: flex;
      justify-content: space-between;
      gap: 14px;
      align-items: center;
      flex-wrap: wrap;
    }

    .deck-nav {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
    }

    .deck-progress {
      min-width: 180px;
      flex: 1;
      max-width: 340px;
      height: 10px;
      border-radius: 999px;
      overflow: hidden;
      background: rgba(29, 107, 87, 0.12);
    }

    .deck-progress > span {
      display: block;
      height: 100%;
      width: 0%;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--accent), var(--accent-2));
    }

    .sidebar {
      border-left: 1px solid var(--line);
      padding: 24px 20px;
      background: rgba(245, 238, 227, 0.62);
      display: grid;
      grid-template-rows: auto auto 1fr auto;
      gap: 18px;
    }

    .sidebar h3 {
      margin: 0;
      font-size: 1.05rem;
    }

    .slide-list {
      display: grid;
      gap: 8px;
      align-content: start;
      max-height: 46vh;
      overflow: auto;
      padding-right: 4px;
    }

    .slide-jump {
      width: 100%;
      text-align: left;
      border-radius: 18px;
      padding: 12px 14px;
      background: rgba(255, 255, 255, 0.64);
    }

    .slide-jump.is-active {
      color: #fff;
      background: linear-gradient(135deg, var(--accent), var(--accent-3));
    }

    .sidebar-copy {
      color: var(--muted);
      line-height: 1.55;
      font-size: 0.95rem;
    }

    .status-block {
      border: 1px solid var(--line);
      border-radius: 20px;
      padding: 16px;
      background: rgba(255, 255, 255, 0.58);
    }

    .status-block code {
      font-family: "Consolas", "SFMono-Regular", "Courier New", monospace;
      font-size: 0.9rem;
    }

    .loading,
    .error {
      min-height: 58vh;
      display: grid;
      place-items: center;
      padding: 32px;
      text-align: center;
    }

    .error {
      color: #7d2318;
    }

    .visually-hidden {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    @media (max-width: 980px) {
      .app-card {
        grid-template-columns: 1fr;
        min-height: auto;
      }

      .sidebar {
        border-left: 0;
        border-top: 1px solid var(--line);
      }

      .slide-list {
        max-height: none;
      }
    }

    @media (max-width: 720px) {
      .topbar {
        padding-left: 14px;
        padding-right: 14px;
      }

      .app-card {
        margin: 12px 14px 14px;
        border-radius: 24px;
      }

      .stage,
      .sidebar {
        padding: 18px 16px;
      }

      .slide {
        padding: 20px;
      }

      .slide h1,
      .slide h2 {
        max-width: none;
      }
    }
  </style>
</head>
<body>
  <div class="app-shell">
    <div class="ambient" aria-hidden="true"></div>
    <header class="topbar">
      <div class="brand">
        <div class="brand-mark" aria-hidden="true"></div>
        <div class="brand-copy">
          <div class="eyebrow">GitHub Status Deck</div>
          <strong>{{ username }} public activity</strong>
        </div>
      </div>
      <div class="top-actions" aria-label="Deck mode">
        <button id="mode-7d" type="button" class="is-active">Weekly deck</button>
        <button id="mode-30d" type="button">Monthly deck</button>
      </div>
    </header>

    <main class="app-card">
      <section class="stage">
        <div class="stage-header">
          <div>
            <div class="eyebrow" id="deck-label">Loading slides</div>
            <div class="stage-meta" id="deck-meta">
              <span class="meta-chip">Static site</span>
              <span class="meta-chip">Powered by nightly JSON + TOML</span>
            </div>
          </div>
          <div class="deck-nav">
            <button id="prev-slide" type="button" aria-label="Previous slide">Back</button>
            <button id="next-slide" type="button" aria-label="Next slide">Next</button>
          </div>
        </div>

        <div id="slide-frame" class="slide-frame" aria-live="polite">
          <div class="loading">
            <div>
              <div class="eyebrow">Preparing deck</div>
              <h2 style="margin-top: 10px;">Loading the latest GitHub snapshot</h2>
              <p class="lede">The browser is reading the generated static feeds and turning them into a guided status story.</p>
            </div>
          </div>
        </div>

        <div class="deck-controls">
          <div class="deck-progress" aria-hidden="true"><span id="deck-progress-bar"></span></div>
          <div class="stage-meta">
            <span class="meta-chip" id="slide-counter">0 / 0</span>
            <span class="meta-chip">Arrow keys work too</span>
          </div>
        </div>
      </section>

      <aside class="sidebar">
        <div>
          <div class="eyebrow">Navigation</div>
          <h3 id="sidebar-title">Deck outline</h3>
        </div>
        <div class="sidebar-copy" id="sidebar-copy">
          Weekly mode should feel like a punchy briefing. Monthly mode stretches the same data into a longer retrospective.
        </div>
        <div id="slide-list" class="slide-list" aria-label="Slides"></div>
        <div class="status-block">
          <div class="eyebrow">Feed files</div>
          <div id="feed-links" class="feed-grid" style="margin-top: 12px;">
            {% for link in links %}
            <a class="feed-card" href="{{ link.html }}">
              <div class="card-label">{{ link.label }}</div>
              <div class="detail">HTML reader: <code>{{ link.html }}</code></div>
              <div class="detail">JSON: <code>{{ link.json }}</code></div>
              <div class="detail">TOML: <code>{{ link.toml }}</code></div>
            </a>
            {% endfor %}
          </div>
        </div>
      </aside>
    </main>
  </div>

  <script>
    window.GH_STATUS_BOOTSTRAP = {{ bootstrap | tojson }};
  </script>
  <script src="app.js"></script>
  <noscript>
    This site works best with JavaScript enabled because the deck is assembled from static JSON feeds in the browser.
  </noscript>
</body>
</html>
